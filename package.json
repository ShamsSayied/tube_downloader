{
  "name": "tube-downloader",
  "version": "2.2.0",
  "description": "Tube Downloader — Standalone desktop media download manager powered by yt-dlp",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "node scripts/download-binaries.js",
    "build": "electron-builder --win zip nsis portable && node scripts/rename-builds.js",
    "build:zip": "electron-builder --win zip && node scripts/rename-builds.js",
    "build:portable": "electron-builder --win portable",
    "build:nsis": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.naharsoft.tube-downloader",
    "productName": "Tube Downloader",
    "copyright": "Copyright © 2024 NaharSoft",
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "zip",
        "nsis",
        "portable"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "artifactName": "TubeDownloader-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "TubeDownloader-Standalone-${version}.${ext}"
    }
  }
}
